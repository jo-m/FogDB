strict_env

# This file contains only a minimal set of options, for development.
# Run the binary with --help to show all available.

# Goose CLI tools (needed for db migrations in development only).
export GOOSE_DRIVER=sqlite3
export GOOSE_DBSTRING="$(expand_path data/db.sqlite)"
export GOOSE_MIGRATION_DIR="$(expand_path internal/db/migrations)"

export FOGDB_DB=data/db.sqlite
